# linkhop backend — Beispielkonfiguration
#
# Kopie als backend/.env anlegen und Werte ausfüllen. Alle Variablen sind
# optional; auskommentierte Zeilen zeigen die Defaults aus config.py.
# .env wird nur geladen, wenn uvicorn/pytest aus dem backend-Verzeichnis
# gestartet wird (pydantic-settings sucht im CWD).

# --- Infrastruktur -----------------------------------------------------------
# Defaults passen zu backend/docker-compose.yml (Postgres + Redis lokal).
# LINKHOP_DATABASE_URL=postgresql+asyncpg://linkhop:linkhop@localhost:5432/linkhop
# LINKHOP_REDIS_URL=redis://localhost:6379/0

# --- Rate-Limits & Cache -----------------------------------------------------
# LINKHOP_RATE_ANONYMOUS=20
# LINKHOP_RATE_WITH_KEY=300
# LINKHOP_CACHE_TTL=604800

# --- Service-Toggles ---------------------------------------------------------
# Deezer benötigt keine Credentials. Ohne Spotify-/Tidal-Keys die entsprechende
# Service-Integration per Flag abschalten, sonst liefern Conversions 5xx.
# LINKHOP_ENABLE_SPOTIFY=true
# LINKHOP_ENABLE_DEEZER=true
# LINKHOP_ENABLE_TIDAL=true

# --- Spotify-Credentials -----------------------------------------------------
# https://developer.spotify.com/dashboard -> App anlegen -> Client ID/Secret
LINKHOP_SPOTIFY_CLIENT_ID=
LINKHOP_SPOTIFY_CLIENT_SECRET=

# --- Tidal-Credentials -------------------------------------------------------
# https://developer.tidal.com -> OAuth-Client (Client Credentials Flow)
LINKHOP_TIDAL_CLIENT_ID=
LINKHOP_TIDAL_CLIENT_SECRET=

# --- CORS & Logging ----------------------------------------------------------
# Komma-separierte Liste; "*" erlaubt alle Origins (nur für lokale Tests).
# LINKHOP_CORS_ALLOW_ORIGINS=*
# LINKHOP_LOG_LEVEL=INFO
